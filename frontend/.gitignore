# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*



# Carpetas y archivos comunes a ignorar
.git
.github
.gitignore
README.md
LICENSE
docs

# Backend (Python)
backend/__pycache__/
backend/venv/
backend/.env
